# cethos.com — environment template
# ---------------------------------------------------------------------------
# Copy to .env.local (Next.js reads it automatically) and fill in real
# values. Never commit .env or .env.local. The root .gitignore excludes
# them by default; .env.example is the only env file checked into git.
#
# For production, set the same variables in Netlify → Site settings →
# Environment variables for the cethos.com site.
#
# Security note (May 2026): the legacy Supabase anon/service_role keys
# were rotated after a public-key exposure incident. Use the new
# `sb_publishable_...` and `sb_secret_...` keys from the Supabase
# Dashboard → API Keys → "Publishable and secret API keys" tab.
# ---------------------------------------------------------------------------


# === Site identity ==========================================================
NEXT_PUBLIC_SITE_URL=https://cethos.com
# Link target for the certified-quote handoff button. Defaults to
# https://portal.cethos.com if unset.
NEXT_PUBLIC_PORTAL_URL=https://portal.cethos.com


# === Supabase — primary project (Cethos Translation App) ===================
# NEXT_PUBLIC_* are embedded into the browser bundle at build time. Safe
# because the publishable key relies on RLS for access control.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server-only mirror for code paths that build a service-role client.
# Some routes read SUPABASE_URL directly (not the NEXT_PUBLIC_ form); set
# both to the same value.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role / secret key — server-side only. Never expose to the
# client. Read by Brevo email routes, admin endpoints, i18n loaders,
# and seed scripts that need to bypass RLS.
# Some legacy paths read SUPABASE_SERVICE_KEY; set both to the same
# value to avoid drift.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_SERVICE_KEY=sb_secret_...


# === Supabase — automations / GA / Ads pipeline (separate project) =========
# Read by lib/cethos-automations.ts. Used by /api/automations-ping and
# any marketing-data routes that hit the GoogleAds/GBP/GA4/etc. edge
# function on a different Supabase project. Leave blank if you don't
# operate the automations project locally.
CETHOS_AUTOMATIONS_URL=
CETHOS_AUTOMATIONS_SERVICE_ROLE_KEY=


# === Email — Brevo (transactional) =========================================
# Every quote-intake endpoint (/api/quote, /api/certified-quote, /api/
# apostille-quote, etc.) sends a notification via Brevo.
BREVO_API_KEY=
# Comma-separated list of internal recipients for new-quote alerts.
# Defaults to info@cethos.com when unset.
QUOTE_EMAIL_RECIPIENTS=info@cethos.com


# === Cal.com — apostille consultation booking ==============================
# Used by /api/apostille-consult/*. Defaults below match production.
CAL_API_BASE=https://api.cal.com/v2
CAL_USERNAME=cethos
CAL_EVENT_SLUG=apostille-consult
CAL_API_KEY=


# === Analytics =============================================================
# PostHog — client-side analytics. Embedded into the bundle.
NEXT_PUBLIC_POSTHOG_KEY=


# === Admin / AI ============================================================
# Server-side key for the /api/admin/ai-assist endpoint.
AI_PROVIDER_API_KEY=


# === Build flags ===========================================================
# Set ANALYZE=true to enable the bundle analyzer during `next build`.
# ANALYZE=true
